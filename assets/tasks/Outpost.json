{
    "task": [
        {
            "name": "Outpost",
            "label": "$task.Outpost.label",
            "entry": "OutpostMain",
            "description": "$task.Outpost.description",
            "option": [
                "DefenseRewards",
                "BulletinBoard",
                "BriefEncounter"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "DefenseRewards": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.DefenseRewards.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "OutpostEnterDefenseRewards": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "OutpostEnterDefenseRewards": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "BulletinBoard": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.BulletinBoard.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "OutpostEnterBulletinBoard": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "OutpostEnterBulletinBoard": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "BriefEncounter": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.BriefEncounter.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "BriefEncounter": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "BriefEncounter": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
